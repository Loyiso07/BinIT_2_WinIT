@model BinIT2WinIT.Models.CollectionOfficer

@{
    ViewBag.Title = "Verification Statistics";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <!-- Page Header -->
    <div class="row">
        <div class="col-12">
            <h2><i class="fas fa-chart-bar text-primary"></i> Verification Statistics</h2>
            <p class="text-muted">View your performance and verification history.</p>
            <hr />
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row mt-4">
        <div class="col-md-3">
            <div class="card bg-success text-white shadow">
                <div class="card-body text-center">
                    <i class="fas fa-check-circle fa-2x mb-2"></i>
                    <h3>@ViewBag.TotalVerified</h3>
                    <p class="mb-0">Total Verified</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white shadow">
                <div class="card-body text-center">
                    <i class="fas fa-times-circle fa-2x mb-2"></i>
                    <h3>@ViewBag.TotalRejected</h3>
                    <p class="mb-0">Total Rejected</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white shadow">
                <div class="card-body text-center">
                    <i class="fas fa-weight fa-2x mb-2"></i>
                    <h3>@ViewBag.TotalWeightVerified.ToString("0.0") kg</h3>
                    <p class="mb-0">Total Weight Verified</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-dark shadow">
                <div class="card-body text-center">
                    <i class="fas fa-percent fa-2x mb-2"></i>
                    <h3>
                        @{
                            var total = ViewBag.TotalVerified + ViewBag.TotalRejected;
                            var rate = total > 0 ? (ViewBag.TotalVerified / (double)total * 100) : 0;
                        }
                        @rate.ToString("0.0")%
                    </h3>
                    <p class="mb-0">Approval Rate</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Officer Info -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header bg-dark text-white">
                    <i class="fas fa-user"></i> Officer Information
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Name:</strong> @Model.FullName</p>
                            <p><strong>Employee Number:</strong> @Model.EmployeeNumber</p>
                            <p><strong>Department:</strong> @Model.Department</p>
                        </div>
                        <div class="col-md-6">
                            <p>
                                <strong>Assigned Drop-Off Point:</strong>
                                @(Model.AssignedDropOffPoint?.Name ?? "Not Assigned")
                            </p>
                            <p><strong>Joined:</strong> @Model.CreatedAt.ToShortDateString()</p>
                            <p>
                                <strong>Status:</strong>
                                @if (Model.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header bg-secondary text-white">
                    <i class="fas fa-bolt"></i> Quick Actions
                </div>
                <div class="card-body">
                    <a href="@Url.Action("Pending", "Officer")" class="btn btn-warning">
                        <i class="fas fa-clock"></i> View Pending Submissions
                    </a>
                    <a href="@Url.Action("Dashboard", "Officer")" class="btn btn-primary ms-2">
                        <i class="fas fa-home"></i> Back to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>