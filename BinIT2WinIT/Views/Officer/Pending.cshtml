@model IEnumerable<BinIT2WinIT.Models.RecyclingSubmission>

@{
    ViewBag.Title = "Pending Submissions";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <!-- Success/Error Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <h2><i class="fas fa-clock text-warning"></i> Pending Submissions</h2>
    <p class="text-muted">Review and verify recycling submissions from residents.</p>
    <hr />

    @if (Model != null && Model.Any())
    {
        <div class="card shadow">
            <div class="card-header bg-dark text-white">
                <i class="fas fa-list"></i> Pending Submissions
                <span class="badge bg-warning text-dark ms-2">@Model.Count()</span>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th>Date</th>
                                <th>Resident</th>
                                <th>Material</th>
                                <th>Weight (kg)</th>
                                <th>Drop-Off Point</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var submission in Model.OrderBy(s => s.SubmissionDate))
                            {
                                <tr>
                                    <td>@submission.SubmissionDate.ToString("dd MMM yyyy HH:mm")</td>
                                    <!-- ✅ FIXED: Use Resident.FullName -->
                                    <td>@(submission.Resident?.FullName ?? "Unknown Resident")</td>
                                    <!-- ✅ FIXED: Use MaterialType.Name -->
                                    <td>@(submission.MaterialType?.Name ?? "Unknown Material")</td>
                                    <td>@submission.Weight.ToString("0.0")</td>
                                    <!-- ✅ FIXED: Use DropOffPoint.Name -->
                                    <td>@(submission.DropOffPoint?.Name ?? "Unknown Location")</td>
                                    <td>
                                        @using (Html.BeginForm("Confirm", "Officer", FormMethod.Post, new { style = "display:inline;" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="submissionId" value="@submission.SubmissionId" />
                                            <button type="submit" class="btn btn-success btn-sm" onclick="return confirm('Confirm this submission?')">
                                                <i class="fas fa-check"></i> Confirm
                                            </button>
                                        }
                                        @using (Html.BeginForm("Reject", "Officer", FormMethod.Post, new { style = "display:inline;" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="submissionId" value="@submission.SubmissionId" />
                                            <input type="text" name="reason" placeholder="Reason for rejection" class="form-control form-control-sm d-inline-block w-auto" required />
                                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Reject this submission?')">
                                                <i class="fas fa-times"></i> Reject
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-check-circle"></i> No pending submissions. Great job!
        </div>
    }

    <!-- Navigation -->
    <div class="mt-3">
        @Html.ActionLink("← Back to Dashboard", "Dashboard", "Officer", null, new { @class = "btn btn-outline-secondary" })
    </div>
</div>