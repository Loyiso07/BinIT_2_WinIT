@model IEnumerable<BinIT2WinIT.Models.Resident>

@{
    ViewBag.Title = "Leaderboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2><i class="fas fa-trophy text-warning"></i> Community Leaderboard</h2>
    <p class="text-muted">Top recyclers in your community</p>
    <hr />

    @if (Model != null && Model.Any())
    {
        <div class="card shadow">
            <div class="card-header bg-dark text-white">
                <i class="fas fa-crown"></i> Top 10 Recyclers
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Rank</th>
                                <th>Resident</th>
                                <th>Points</th>
                                <th>CO2 Saved</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int rank = 1;
                            }
                            @foreach (var resident in Model)
                            {
                                var isCurrentUser = ViewBag.CurrentResident != null &&
                                    resident.ResidentId == ViewBag.CurrentResident.ResidentId;

                                <tr class="@(isCurrentUser ? "table-success fw-bold" : "")">
                                    <td>
                                        @if (rank == 1)
                                        {
                                            <span class="badge bg-warning">🥇</span>
                                        }
                                        else if (rank == 2)
                                        {
                                            <span class="badge bg-secondary">🥈</span>
                                        }
                                        else if (rank == 3)
                                        {
                                            <span class="badge bg-danger">🥉</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-dark">@rank</span>
                                        }
                                    </td>
                                    <td>
                                        @resident.FullName
                                        @if (isCurrentUser)
                                        {
                                            <span class="badge bg-success">You</span>
                                        }
                                    </td>
                                    <td><strong>@resident.PointsBalance</strong></td>
                                    <td>@resident.TotalCO2Saved.ToString("0.0") kg</td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i>
            No recycling data yet. Encourage residents to start recycling!
        </div>
    }

    <div class="mt-3">
        @Html.ActionLink("← Back to Dashboard", "Dashboard", "Officer", null, new { @class = "btn btn-outline-secondary" })
    </div>
</div>

