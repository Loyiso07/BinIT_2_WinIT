@model IEnumerable<BinIT2WinIT.Models.PointsRate>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.MaterialType.Name)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.PointsPerKg)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.EffectiveDate)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.EndDate)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.IsActive)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.MaterialType.Name)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.PointsPerKg)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.EffectiveDate)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.EndDate)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.IsActive)
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.PointsRateId }) |
            @Html.ActionLink("Details", "Details", new { id=item.PointsRateId }) |
            @Html.ActionLink("Delete", "Delete", new { id=item.PointsRateId })
        </td>
    </tr>
}

</table>
