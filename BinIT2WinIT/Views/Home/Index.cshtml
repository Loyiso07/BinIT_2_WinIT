@{
    ViewBag.Title = "Home Page";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<main>
    <!-- Hero Section -->
    <div class="hero-section text-center">
        <div class="container">
            <h1><i class="fas fa-recycle"></i> BinIT2WinIT</h1>
            <p class="lead">Smart Recycling Rewards System</p>
            <p class="mb-4">Earn points, save the planet, and win rewards for recycling!</p>
            @if (!User.Identity.IsAuthenticated)
            {
                <div>
                    <a href="@Url.Action("Login", "Account")" class="btn btn-light btn-lg me-2">
                        <i class="fas fa-sign-in-alt"></i> Login
                    </a>
                    <a href="@Url.Action("Register", "Account")" class="btn btn-outline-light btn-lg">
                        <i class="fas fa-user-plus"></i> Register
                    </a>
                </div>
            }
            else
            {
                <div>
                    @if (User.IsInRole("Resident"))
                    {
                        <a href="@Url.Action("Dashboard", "Resident")" class="btn btn-light btn-lg me-2">
                            <i class="fas fa-home"></i> Dashboard
                        </a>
                        <a href="@Url.Action("SubmitRecycling", "Resident")" class="btn btn-outline-light btn-lg">
                            <i class="fas fa-recycle"></i> Recycle Now
                        </a>
                    }
                    else if (User.IsInRole("CollectionOfficer"))
                    {
                        <a href="@Url.Action("Dashboard", "Officer")" class="btn btn-light btn-lg">
                            <i class="fas fa-clipboard-check"></i> Officer Dashboard
                        </a>
                    }
                    else if (User.IsInRole("Administrator"))
                    {
                        <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-light btn-lg">
                            <i class="fas fa-cog"></i> Admin Dashboard
                        </a>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Stats Section (Visible when logged in) -->
    @if (User.Identity.IsAuthenticated && User.IsInRole("Resident"))
    {
        <div class="row mb-4 text-center">
            <div class="col-md-3">
                <div class="card feature-card p-3">
                    <div class="card-body">
                        <div class="stat-number">@ViewBag.PointsBalance</div>
                        <p class="text-muted">Total Points</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card feature-card p-3">
                    <div class="card-body">
                        <div class="stat-number">@ViewBag.InfluencerPoints</div>
                        <p class="text-muted">Influencer Points</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card feature-card p-3">
                    <div class="card-body">
                        <div class="stat-number">@ViewBag.Co2Saved</div>
                        <p class="text-muted">CO2 Saved (kg)</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card feature-card p-3">
                    <div class="card-body">
                        <div class="stat-number">@ViewBag.Rank</div>
                        <p class="text-muted">Leaderboard Rank</p>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Feature Cards -->
    <div class="row">
        <!-- For Residents -->
        <div class="col-md-4 mb-4">
            <div class="card feature-card text-center p-4">
                <div class="feature-icon text-success">
                    <i class="fas fa-user"></i>
                </div>
                <h4>Resident Portal</h4>
                <p class="text-muted">Submit recycling, track your points, and see your environmental impact.</p>
                @if (User.Identity.IsAuthenticated && User.IsInRole("Resident"))
                {
                    <a href="@Url.Action("Dashboard", "Resident")" class="btn btn-recycle">
                        <i class="fas fa-arrow-right"></i> Go to Dashboard
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Login", "Account")" class="btn btn-outline-success">
                        <i class="fas fa-sign-in-alt"></i> Login
                    </a>
                }
            </div>
        </div>

        <!-- For Collection Officers -->
        <div class="col-md-4 mb-4">
            <div class="card feature-card text-center p-4">
                <div class="feature-icon text-primary">
                    <i class="fas fa-clipboard-check"></i>
                </div>
                <h4>Officer Portal</h4>
                <p class="text-muted">Verify recycling submissions, award points, and manage collections.</p>
                @if (User.Identity.IsAuthenticated && User.IsInRole("CollectionOfficer"))
                {
                    <a href="@Url.Action("Dashboard", "Officer")" class="btn btn-recycle">
                        <i class="fas fa-arrow-right"></i> Go to Dashboard
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Login", "Account")" class="btn btn-outline-primary">
                        <i class="fas fa-sign-in-alt"></i> Login
                    </a>
                }
            </div>
        </div>

        <!-- For Administrators -->
        <div class="col-md-4 mb-4">
            <div class="card feature-card text-center p-4">
                <div class="feature-icon text-warning">
                    <i class="fas fa-cog"></i>
                </div>
                <h4>Admin Portal</h4>
                <p class="text-muted">Manage users, configure points rates, and generate reports.</p>
                @if (User.Identity.IsAuthenticated && User.IsInRole("Administrator"))
                {
                    <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-recycle">
                        <i class="fas fa-arrow-right"></i> Go to Dashboard
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Login", "Account")" class="btn btn-outline-warning">
                        <i class="fas fa-sign-in-alt"></i> Login
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- Quick Links Section -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card feature-card p-4">
                <h4 class="text-center mb-3"><i class="fas fa-link"></i> Quick Links</h4>
                <div class="row text-center">
                    @if (User.Identity.IsAuthenticated)
                    {
                        if (User.IsInRole("Resident"))
                        {
                            <div class="col-md-3 col-6 mb-2">
                                <a href="@Url.Action("SubmitRecycling", "Resident")" class="btn btn-success w-100">
                                    <i class="fas fa-recycle"></i> Submit Recycling
                                </a>
                            </div>
                            <div class="col-md-3 col-6 mb-2">
                                <a href="@Url.Action("PointsHistory", "Resident")" class="btn btn-info w-100 text-white">
                                    <i class="fas fa-history"></i> Points History
                                </a>
                            </div>
                            <div class="col-md-3 col-6 mb-2">
                                <a href="@Url.Action("Leaderboard", "Resident")" class="btn btn-warning w-100">
                                    <i class="fas fa-trophy"></i> Leaderboard
                                </a>
                            </div>
                            <div class="col-md-3 col-6 mb-2">
                                <a href="@Url.Action("InfluencerPoints", "Resident")" class="btn btn-secondary w-100">
                                    <i class="fas fa-share-alt"></i> Influencer Points
                                </a>
                            </div>
                        }
                        else if (User.IsInRole("CollectionOfficer"))
                        {
                            <div class="col-md-6 col-12 mb-2">
                                <a href="@Url.Action("Pending", "Officer")" class="btn btn-warning w-100">
                                    <i class="fas fa-clock"></i> Pending Submissions
                                </a>
                            </div>
                            <div class="col-md-6 col-12 mb-2">
                                <a href="@Url.Action("Dashboard", "Officer")" class="btn btn-primary w-100">
                                    <i class="fas fa-chart-bar"></i> Statistics
                                </a>
                            </div>
                        }
                        else if (User.IsInRole("Administrator"))
                        {
                            <div class="col-md-4 col-12 mb-2">
                                <a href="@Url.Action("Users", "Admin")" class="btn btn-primary w-100">
                                    <i class="fas fa-users"></i> Manage Users
                                </a>
                            </div>
                            <div class="col-md-4 col-12 mb-2">
                                <a href="@Url.Action("PointsRates", "Admin")" class="btn btn-success w-100">
                                    <i class="fas fa-coins"></i> Points Rates
                                </a>
                            </div>
                            <div class="col-md-4 col-12 mb-2">
                                <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-info w-100 text-white">
                                    <i class="fas fa-chart-line"></i> Analytics
                                </a>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-md-6 col-12 mb-2">
                            <a href="@Url.Action("Login", "Account")" class="btn btn-primary w-100">
                                <i class="fas fa-sign-in-alt"></i> Login
                            </a>
                        </div>
                        <div class="col-md-6 col-12 mb-2">
                            <a href="@Url.Action("Register", "Account")" class="btn btn-success w-100">
                                <i class="fas fa-user-plus"></i> Register
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- About Section -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card feature-card p-4">
                <h4 class="text-center"><i class="fas fa-info-circle"></i> About BinIT2WinIT</h4>
                <p class="text-center text-muted">
                    BinIT2WinIT is a smart recycling rewards system that encourages recycling through gamification.
                    Earn points, track your environmental impact, and compete with your community!
                </p>
                <div class="text-center">
                    <p class="text-muted small">
                        <i class="fas fa-users"></i> 3 Roles: Resident, Collection Officer, Administrator
                        &nbsp;|&nbsp;
                        <i class="fas fa-star"></i> Earn points for recycling
                        &nbsp;|&nbsp;
                        <i class="fas fa-share-alt"></i> Share referral codes
                    </p>
                </div>
            </div>
        </div>
    </div>
</main>