@{
    ViewBag.Title = "Contact Us";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .contact-hero {
        background: linear-gradient(135deg, #1B5E20 0%, #2E7D32 50%, #388E3C 100%);
        color: white;
        padding: 60px 0;
        border-radius: 12px;
        margin-bottom: 40px;
    }

        .contact-hero h1 {
            font-size: 2.8rem;
            font-weight: 700;
        }

        .contact-hero p {
            font-size: 1.2rem;
            opacity: 0.9;
        }

    .contact-card {
        background: white;
        border-radius: 12px;
        padding: 30px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        height: 100%;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-left: 5px solid #2E7D32;
    }

        .contact-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
        }

        .contact-card .icon {
            font-size: 2.5rem;
            color: #2E7D32;
            margin-bottom: 15px;
        }

        .contact-card h4 {
            font-weight: 600;
            color: #1A1A2E;
            margin-bottom: 12px;
        }

        .contact-card p,
        .contact-card a {
            color: #4A4A5A;
            font-size: 1rem;
        }

        .contact-card a {
            text-decoration: none;
            font-weight: 500;
        }

            .contact-card a:hover {
                color: #2E7D32;
                text-decoration: underline;
            }

    .contact-form-section {
        background: #F8FAF9;
        border-radius: 12px;
        padding: 40px;
        margin-top: 40px;
    }

        .contact-form-section h3 {
            color: #1A1A2E;
            font-weight: 600;
            margin-bottom: 20px;
        }

    .btn-send {
        background: linear-gradient(135deg, #2E7D32, #388E3C);
        color: white;
        border: none;
        padding: 12px 40px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

        .btn-send:hover {
            background: linear-gradient(135deg, #1B5E20, #2E7D32);
            transform: scale(1.02);
            color: white;
        }

    .social-icons a {
        display: inline-block;
        width: 45px;
        height: 45px;
        background: #E8F5E9;
        border-radius: 50%;
        text-align: center;
        line-height: 45px;
        color: #2E7D32;
        font-size: 1.2rem;
        margin-right: 10px;
        transition: all 0.3s ease;
    }

        .social-icons a:hover {
            background: #2E7D32;
            color: white;
            transform: translateY(-3px);
        }

    .business-hours {
        background: #FFF3E0;
        border-radius: 12px;
        padding: 20px;
        border-left: 5px solid #FF8F00;
        margin-top: 20px;
    }

        .business-hours strong {
            color: #E65100;
        }

    .whatsapp-btn {
        background: #25D366;
        color: white;
        border: none;
        padding: 10px 25px;
        border-radius: 50px;
        font-weight: 600;
        transition: all 0.3s ease;
        display: inline-block;
        text-decoration: none;
    }

        .whatsapp-btn:hover {
            background: #1DA851;
            color: white;
            transform: scale(1.02);
        }

    @@media (max-width: 768px) {
        .contact-hero {
            padding: 30px 20px;
        }

            .contact-hero h1 {
                font-size: 2rem;
            }

        .contact-card {
            margin-bottom: 20px;
        }

        .contact-form-section {
            padding: 20px;
        }
    }
</style>

<main>
    <!-- Hero Section -->
    <div class="contact-hero text-center">
        <div class="container">
            <h1>📞 Get in Touch</h1>
            <p class="lead">We'd love to hear from you! Whether you have a question, feedback, or want to partner with us, reach out to the BinIT2WinIT team.</p>
        </div>
    </div>

    <div class="container">
        <!-- Contact Cards Row -->
        <div class="row">
            <!-- Call Us -->
            <div class="col-md-4">
                <div class="contact-card text-center">
                    <div class="icon">📱</div>
                    <h4>Call Us</h4>
                    <p>
                        <strong>Phone:</strong><br />
                        <a href="tel:+27821234567">+27 82 123 4567</a>
                    </p>
                    <p>
                        <strong>WhatsApp:</strong><br />
                        <a href="https://wa.me/27821234567" target="_blank" class="whatsapp-btn">
                            <i class="fab fa-whatsapp"></i> Chat on WhatsApp
                        </a>
                    </p>
                </div>
            </div>

            <!-- Email Us -->
            <div class="col-md-4">
                <div class="contact-card text-center">
                    <div class="icon">✉️</div>
                    <h4>Email Us</h4>
                    <p>
                        <strong>General Enquiries:</strong><br />
                        <a href="mailto:info@binit2winit.co.za">info@binit2winit.co.za</a>
                    </p>
                    <p>
                        <strong>Support:</strong><br />
                        <a href="mailto:support@binit2winit.co.za">support@binit2winit.co.za</a>
                    </p>
                </div>
            </div>

            <!-- Visit Us -->
            <div class="col-md-4">
                <div class="contact-card text-center">
                    <div class="icon">📍</div>
                    <h4>Visit Us</h4>
                    <p>
                        <strong>Head Office:</strong><br />
                        123 Anton Lembede Street<br />
                        Durban CBD, 4001<br />
                        KwaZulu-Natal, South Africa
                    </p>
                </div>
            </div>
        </div>

        <!-- Business Hours -->
        <div class="row mt-3">
            <div class="col-12">
                <div class="business-hours">
                    <h5><i class="fas fa-clock"></i> Business Hours</h5>
                    <p class="mb-0">
                        <strong>Monday - Friday:</strong> 8:00 AM – 5:00 PM (SAST)<br />
                        <strong>Saturday:</strong> 9:00 AM – 1:00 PM<br />
                        <strong>Sunday & Public Holidays:</strong> Closed
                    </p>
                </div>
            </div>
        </div>

        <!-- Contact Form Section -->
        <div class="contact-form-section">
            <div class="row">
                <div class="col-md-6">
                    <h3>📩 Send Us a Message</h3>
                    <p>Fill in the form and we'll get back to you within 24 hours.</p>

                    @using (Html.BeginForm("Contact", "Home", FormMethod.Post, new { @class = "needs-validation" }))
                    {
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label for="FullName" class="form-label fw-semibold">Full Name</label>
                            <input type="text" name="FullName" class="form-control form-control-lg" placeholder="Enter your full name" required />
                        </div>

                        <div class="mb-3">
                            <label for="Email" class="form-label fw-semibold">Email Address</label>
                            <input type="email" name="Email" class="form-control form-control-lg" placeholder="Enter your email address" required />
                        </div>

                        <div class="mb-3">
                            <label for="Phone" class="form-label fw-semibold">Phone Number</label>
                            <input type="tel" name="Phone" class="form-control form-control-lg" placeholder="+27 82 123 4567" />
                        </div>

                        <div class="mb-3">
                            <label for="Subject" class="form-label fw-semibold">Subject</label>
                            <select name="Subject" class="form-select form-select-lg">
                                <option value="General Enquiry">General Enquiry</option>
                                <option value="Support">Technical Support</option>
                                <option value="Partnership">Partnership Opportunity</option>
                                <option value="Feedback">Feedback / Suggestion</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="Message" class="form-label fw-semibold">Message</label>
                            <textarea name="Message" class="form-control form-control-lg" rows="5" placeholder="Write your message here..." required></textarea>
                        </div>

                        <button type="submit" class="btn btn-send">
                            <i class="fas fa-paper-plane"></i> Send Message
                        </button>
                    }

                    <div class="mt-3 text-muted small">
                        <i class="fas fa-lock"></i> Your information is safe and will not be shared with third parties.
                    </div>
                </div>

                <div class="col-md-6">
                    <h3>🌍 Connect With Us</h3>
                    <p>Follow us on social media for updates, recycling tips, and community news!</p>

                    <div class="social-icons">
                        <a href="#" target="_blank"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" target="_blank"><i class="fab fa-twitter"></i></a>
                        <a href="#" target="_blank"><i class="fab fa-instagram"></i></a>
                        <a href="#" target="_blank"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#" target="_blank"><i class="fab fa-youtube"></i></a>
                    </div>

                    <hr />

                    <div class="mt-4">
                        <h5><i class="fas fa-map-pin text-success"></i> Our Location</h5>
                        <p class="text-muted">
                            <strong>BinIT2WinIT (Pty) Ltd</strong><br />
                            123 Anton Lembede Street<br />
                            Durban CBD, 4001<br />
                            KwaZulu-Natal, South Africa
                        </p>
                        <p class="text-muted">
                            <i class="fas fa-envelope"></i> <a href="mailto:info@binit2winit.co.za">info@binit2winit.co.za</a><br />
                            <i class="fas fa-phone"></i> <a href="tel:+27821234567">+27 82 123 4567</a>
                        </p>
                    </div>

                    <div class="mt-4 p-3 bg-light rounded">
                        <h5><i class="fas fa-hand-holding-heart text-success"></i> Join the Movement!</h5>
                        <p class="mb-0">Every bin counts. Every action matters. Together we can create a cleaner, greener South Africa.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom Section -->
        <div class="row mt-4">
            <div class="col-12 text-center text-muted small">
                <p><i class="fas fa-recycle text-success"></i> BinIT2WinIT – Smart Recycling Rewards System | © @DateTime.Now.Year All Rights Reserved</p>
            </div>
        </div>
    </div>
</main>