@model BinIT2WinIT.Models.RecyclingSubmissionViewModel

@{
    ViewBag.Title = "Submit Recycling";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white text-center">
                    <h4><i class="fas fa-recycle"></i> Submit Recycling</h4>
                    <p class="mb-0">Earn points by recycling responsibly!</p>
                </div>
                <div class="card-body">
                    <!-- Display success message if any -->
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @using (Html.BeginForm("SubmitRecycling", "Resident", FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <div class="form-group mb-3">
                            @Html.LabelFor(m => m.MaterialTypeId, "Material Type", new { @class = "form-label fw-bold" })
                            @Html.DropDownListFor(m => m.MaterialTypeId,
                                new SelectList(Model.MaterialTypes, "MaterialTypeId", "Name"),
                                "-- Select Material Type --",
                                new { @class = "form-control", required = "required" })
                            @Html.ValidationMessageFor(m => m.MaterialTypeId, "", new { @class = "text-danger" })
                            <small class="text-muted">Select the type of material you are recycling.</small>
                        </div>

                        <div class="form-group mb-3">
                            @Html.LabelFor(m => m.DropOffPointId, "Drop-Off Point", new { @class = "form-label fw-bold" })
                            @Html.DropDownListFor(m => m.DropOffPointId,
                                new SelectList(Model.DropOffPoints, "DropOffPointId", "Name"),
                                "-- Select Drop-Off Point --",
                                new { @class = "form-control", required = "required" })
                            @Html.ValidationMessageFor(m => m.DropOffPointId, "", new { @class = "text-danger" })
                            <small class="text-muted">Where did you drop off your recycling?</small>
                        </div>

                        <div class="form-group mb-3">
                            @Html.LabelFor(m => m.Weight, "Weight (kg)", new { @class = "form-label fw-bold" })
                            <div class="input-group">
                                @Html.TextBoxFor(m => m.Weight, new { @class = "form-control", placeholder = "Enter weight in kg", type = "number", step = "0.1", min = "0.1", required = "required" })
                                <span class="input-group-text">kg</span>
                            </div>
                            @Html.ValidationMessageFor(m => m.Weight, "", new { @class = "text-danger" })
                            <small class="text-muted">Enter the total weight of your recycling (minimum 0.1 kg).</small>
                        </div>

                        <!-- Estimated Points Display -->
                        <div class="alert alert-info" id="estimatedPointsAlert" style="display: none;">
                            <i class="fas fa-calculator"></i> Estimated Points: <strong id="estimatedPointsValue">0</strong>
                            <p class="mb-0 small">This is an estimate. Actual points will be awarded after verification.</p>
                        </div>

                        <div class="form-group mb-3">
                            <button type="submit" class="btn btn-success w-100">
                                <i class="fas fa-paper-plane"></i> Submit Recycling
                            </button>
                        </div>
                    }

                    <hr />
                    <div class="text-center">
                        @Html.ActionLink("← Back to Dashboard", "Dashboard", "Resident", null, new { @class = "text-success" })
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script type="text/javascript">
        $(document).ready(function () {
            // Show/hide estimated points when MaterialType or Weight changes
            $('#MaterialTypeId, #Weight').on('change keyup', function () {
                calculateEstimatedPoints();
            });

            function calculateEstimatedPoints() {
                var materialTypeId = $('#MaterialTypeId').val();
                var weight = parseFloat($('#Weight').val());

                if (materialTypeId && weight > 0) {
                    // Get points rate for selected material
                    // This is a client-side estimate; server will calculate actual points
                    var pointsRates = @Html.Raw(Json.Encode(Model.MaterialTypes.Select(m => new { m.MaterialTypeId, m.PointsRates?.FirstOrDefault(p => p.IsActive)?.PointsPerKg })));
                    var rate = pointsRates.find(r => r.MaterialTypeId === parseInt(materialTypeId));
                    var pointsPerKg = rate ? rate.PointsPerKg : 0;

                    var estimatedPoints = Math.round(weight * pointsPerKg);
                    $('#estimatedPointsValue').text(estimatedPoints);
                    $('#estimatedPointsAlert').show();
                } else {
                    $('#estimatedPointsAlert').hide();
                }
            }
        });
    </script>
}