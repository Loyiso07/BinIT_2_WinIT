@model BinIT2WinIT.Models.Resident

@{
    ViewBag.Title = "Points History";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2><i class="fas fa-history text-primary"></i> Points History</h2>
    <hr />

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-success text-white shadow">
                <div class="card-body text-center">
                    <h4>@Model.PointsBalance</h4>
                    <p>Current Balance</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info text-white shadow">
                <div class="card-body text-center">
                    <h4>@Model.PointsTransactions?.Count ?? 0</h4>
                    <p>Total Transactions</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-warning text-dark shadow">
                <div class="card-body text-center">
                    <h4>@Model.TotalCO2Saved.ToString("0.0") kg</h4>
                    <p>CO2 Saved</p>
                </div>
            </div>
        </div>
    </div>

    @if (Model.PointsTransactions != null && Model.PointsTransactions.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-bordered">
                <thead class="bg-dark text-white">
                    <tr>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Amount</th>
                        <th>Type</th>
                        <th>Running Balance</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var runningBalance = 0;
                    }
                    @foreach (var transaction in Model.PointsTransactions.OrderBy(t => t.TransactionDate))
                    {
                        runningBalance += transaction.Amount;
                        <tr>
                            <td>@transaction.TransactionDate.ToShortDateString()</td>
                            <td>@transaction.Description</td>
                            <td>
                                <span class="@(transaction.Amount > 0 ? "text-success" : "text-danger")">
                                    @(transaction.Amount > 0 ? "+" : "")@transaction.Amount
                                </span>
                            </td>
                            <td>
                                <span class="badge @(transaction.Type == "Earn" ? "bg-success" : transaction.Type == "WelcomeBonus" ? "bg-info" : "bg-danger")">
                                    @transaction.Type
                                </span>
                            </td>
                            <td>@runningBalance</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> No transactions found. Start recycling to earn points!
        </div>
    }

    <div class="mt-3">
        @Html.ActionLink("← Back to Dashboard", "Dashboard", "Resident", null, new { @class = "btn btn-secondary" })
    </div>
</div>