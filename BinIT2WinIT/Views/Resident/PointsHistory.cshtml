@model BinIT2WinIT.Models.Resident

@{
    ViewBag.Title = "Points History";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <!-- Success/Error Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <h2><i class="fas fa-history text-primary"></i> Points History</h2>
    <hr />

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-success text-white shadow">
                <div class="card-body text-center">
                    <h4>@Model.PointsBalance</h4>
                    <p>Current Balance</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info text-white shadow">
                <div class="card-body text-center">
                    <!-- ✅ FIXED: Wrap the expression in parentheses -->
                    <h4>@(Model.PointsTransactions?.Count ?? 0)</h4>
                    <p>Total Transactions</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-warning text-dark shadow">
                <div class="card-body text-center">
                    <h4>@Model.TotalCO2Saved.ToString("0.0") kg</h4>
                    <p>CO2 Saved</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Transactions Table -->
    @if (Model.PointsTransactions != null && Model.PointsTransactions.Any())
    {
        <div class="card shadow">
            <div class="card-header bg-dark text-white">
                <i class="fas fa-list"></i> All Transactions
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th>Date</th>
                                <th>Description</th>
                                <th>Amount</th>
                                <th>Type</th>
                                <th>Running Balance</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var runningBalance = 0;
                            }
                            @foreach (var transaction in Model.PointsTransactions.OrderBy(t => t.TransactionDate))
                            {
                                runningBalance += transaction.Amount;
                                <tr>
                                    <td>@transaction.TransactionDate.ToString("dd MMM yyyy")</td>
                                    <td>@transaction.Description</td>
                                    <td>
                                        <span class="@(transaction.Amount > 0 ? "text-success fw-bold" : "text-danger fw-bold")">
                                            @(transaction.Amount > 0 ? "+" : "")@transaction.Amount
                                        </span>
                                    </td>
                                    <td>
                                        @if (transaction.Type == "Earn")
                                        {
                                            <span class="badge bg-success">Earn</span>
                                        }
                                        else if (transaction.Type == "WelcomeBonus")
                                        {
                                            <span class="badge bg-info">Welcome Bonus</span>
                                        }
                                        else if (transaction.Type == "Reverted")
                                        {
                                            <span class="badge bg-danger">Reverted</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@transaction.Type</span>
                                        }
                                    </td>
                                    <td><strong>@runningBalance</strong></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> No transactions found. Start recycling to earn points!
        </div>
    }

    <!-- Navigation -->
    <div class="mt-3 d-flex justify-content-between">
        @Html.ActionLink("← Back to Dashboard", "Dashboard", "Resident", null, new { @class = "btn btn-outline-secondary" })
        @Html.ActionLink("Submit Recycling →", "SubmitRecycling", "Resident", null, new { @class = "btn btn-success" })
    </div>
</div>