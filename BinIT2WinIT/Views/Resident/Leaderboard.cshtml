@model List<BinIT2WinIT.Models.Resident>

@{
    ViewBag.Title = "Leaderboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2><i class="fas fa-trophy text-warning"></i> Community Leaderboard</h2>
    <hr />

    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-body">
                    <p>Top 10 recyclers in the community. Keep recycling to climb the ranks!</p>
                    @if (ViewBag.CurrentResident != null)
                    {
                        var rank = Model.FindIndex(r => r.UserId == ViewBag.CurrentResident.UserId) + 1;
                        <div class="alert alert-info">
                            <i class="fas fa-user"></i> Your current rank:
                            <strong>#@(rank > 0 ? rank : "Not ranked")</strong> with
                            <strong>@ViewBag.CurrentResident.PointsBalance</strong> points
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-bordered">
                <thead class="bg-dark text-white">
                    <tr>
                        <th>#</th>
                        <th>Full Name</th>
                        <th>Points</th>
                        <th>Influencer Points</th>
                        <th>CO2 Saved (kg)</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var resident = Model[i];
                        var isCurrentUser = ViewBag.CurrentUserId != null && resident.UserId == ViewBag.CurrentUserId.ToString();
                        <tr class="@(isCurrentUser ? "table-success" : "")">
                            <td>
                                @if (i == 0)
                                {
                                    <span class="text-warning"><i class="fas fa-crown"></i> 1</span>
                                }
                                else
                                {
                                    <span>@(i + 1)</span>
                                }
                            </td>
                            <td>@resident.FullName @(isCurrentUser ? "(You)" : "")</td>
                            <td><strong>@resident.PointsBalance</strong></td>
                            <td>@resident.InfluencerPoints</td>
                            <td>@resident.TotalCO2Saved.ToString("0.0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> No residents found. Be the first to start recycling!
        </div>
    }

    <div class="mt-3">
        @Html.ActionLink("← Back to Dashboard", "Dashboard", "Resident", null, new { @class = "btn btn-secondary" })
    </div>
</div>