@model IEnumerable<BinIT2WinIT.Models.Resident>

@{
    ViewBag.Title = "Community Leaderboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h2><i class="fas fa-trophy text-warning"></i> Community Leaderboard</h2>
            <p class="text-muted">See how you compare to other recyclers in your community.</p>
            <hr />
        </div>
    </div>

    <!-- Current User Info -->
    @if (ViewBag.CurrentResident != null)
    {
        <div class="alert alert-info">
            <i class="fas fa-user"></i> Your current rank:
            <!-- ✅ FIXED: Convert int to string -->
            <strong>@(ViewBag.CurrentRank > 0 ? ViewBag.CurrentRank.ToString() : "Not ranked")</strong>
            with
            <strong>@ViewBag.CurrentResident.PointsBalance</strong>
            points
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle"></i> You are not ranked yet. Start recycling to appear on the leaderboard!
        </div>
    }

    <!-- Leaderboard Table -->
    <div class="card shadow">
        <div class="card-header bg-dark text-white">
            <i class="fas fa-crown"></i> Top 10 Recyclers
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Rank</th>
                            <th>Resident</th>
                            <th>Points</th>
                            <th>CO2 Saved</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int currentRank = 1;
                        }
                        @foreach (var resident in Model)
                        {
                            var isCurrentUser = ViewBag.CurrentResident != null && resident.ResidentId == ViewBag.CurrentResident.ResidentId;

                            <tr class="@(isCurrentUser ? "table-success fw-bold" : "")">
                                <td>
                                    @if (currentRank == 1)
                                    {
                                        <span class="badge bg-warning">🥇 1</span>
                                    }
                                    else if (currentRank == 2)
                                    {
                                        <span class="badge bg-secondary">🥈 2</span>
                                    }
                                    else if (currentRank == 3)
                                    {
                                        <span class="badge bg-danger">🥉 3</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-dark">@currentRank</span>
                                    }
                                </td>
                                <td>
                                    @resident.FullName
                                    @if (isCurrentUser)
                                    {
                                        <span class="badge bg-success">You</span>
                                    }
                                </td>
                                <td><strong>@resident.PointsBalance</strong></td>
                                <td>@resident.TotalCO2Saved.ToString("0.0") kg</td>
                            </tr>
                            currentRank++;
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="fas fa-recycle fa-3x text-muted"></i>
                    <p class="text-muted mt-2">No recycling activity yet. Be the first to start recycling!</p>
                </div>
            }
        </div>
    </div>

    <!-- Navigation -->
    <div class="mt-3 d-flex justify-content-between">
        @Html.ActionLink("← Back to Dashboard", "Dashboard", "Resident", null, new { @class = "btn btn-outline-success" })
        @Html.ActionLink("Submit Recycling →", "SubmitRecycling", "Resident", null, new { @class = "btn btn-success" })
    </div>
</div>