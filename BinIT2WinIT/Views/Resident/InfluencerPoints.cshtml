@model BinIT2WinIT.Models.Resident

@{
    ViewBag.Title = "Influencer Points";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2><i class="fas fa-share-alt text-warning"></i> Influencer Points</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <i class="fas fa-gift"></i> Your Referral Code
                </div>
                <div class="card-body text-center">
                    <div class="bg-light p-3 rounded">
                        <h3><code>@Model.ReferralCode</code></h3>
                    </div>
                    <p class="mt-3">Share this code with friends. When they sign up and recycle, you earn influencer points!</p>
                    <button class="btn btn-primary" onclick="copyCode()">
                        <i class="fas fa-copy"></i> Copy Code
                    </button>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <i class="fas fa-chart-line"></i> Your Stats
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-6">
                            <h3>@Model.InfluencerPoints</h3>
                            <p class="text-muted">Influencer Points</p>
                        </div>
                        <div class="col-6">
                            <h3>@Model.TotalReferrals</h3>
                            <p class="text-muted">Total Referrals</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        @Html.ActionLink("← Back to Dashboard", "Dashboard", "Resident", null, new { @class = "btn btn-secondary" })
    </div>
</div>

<script>
    function copyCode() {
        var code = '@Model.ReferralCode';
        navigator.clipboard.writeText(code).then(function() {
            alert('Referral code copied to clipboard!');
        }, function(err) {
            // Fallback for older browsers
            var textArea = document.createElement("textarea");
            textArea.value = code;
            document.body.appendChild(textArea);
            textArea.select();
            document.execCommand("copy");
            document.body.removeChild(textArea);
            alert('Referral code copied to clipboard!');
        });
    }
</script>