@model IEnumerable<BinIT2WinIT.Models.DropOffPoint>

@{
    ViewBag.Title = "Communities";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2><i class="fas fa-city text-warning"></i> Communities</h2>
    <p class="text-muted">Track recycling performance and officer deployment per community.</p>
    <hr />

    <div class="card shadow">
        <div class="card-header bg-dark text-white">
            <i class="fas fa-list"></i> Community Performance
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Community</th>
                                <th>City</th>
                                <th>Officers</th>
                                <th>Residents</th>
                                <th>Submissions</th>
                                <th>Total Points</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var community in Model)
                            {
                                <tr>
                                    <td><strong>@community.Name</strong></td>
                                    <td>@community.City</td>
                                    <td>
                                        <span class="badge bg-primary">@ViewBag.OfficerCounts[community.DropOffPointId]</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-success">@ViewBag.ResidentCounts[community.DropOffPointId]</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@ViewBag.SubmissionCounts[community.DropOffPointId]</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-warning">@ViewBag.PointsCounts[community.DropOffPointId]</span>
                                    </td>
                                    <td>
                                        @if (community.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="@Url.Action("CommunityDetails", "Admin", new { id = community.DropOffPointId })" class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="fas fa-city fa-3x text-muted"></i>
                    <p class="text-muted mt-2">No communities found.</p>
                </div>
            }
        </div>
    </div>

    <div class="mt-3">
        @Html.ActionLink("← Back to Dashboard", "Dashboard", "Admin", null, new { @class = "btn btn-outline-secondary" })
    </div>
</div>

