@model IEnumerable<BinIT2WinIT.Models.CollectionOfficer>

@{
    ViewBag.Title = "Manage Officers";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="d-flex justify-content-between align-items-center">
        <h2><i class="fas fa-user-tie text-primary"></i> Collection Officers</h2>
        @Html.ActionLink("+ Create Officer", "CreateOfficer", "Admin", null, new { @class = "btn btn-success" })
    </div>
    <hr />

    <div class="card shadow">
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Employee Number</th>
                            <th>Region</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var officer in Model)
                        {
                            <tr>
                                <td>@officer.FullName</td>
                                <td>@(officer.User?.Email ?? "N/A")</td>
                                <td>@officer.EmployeeNumber</td>
                                <td>
                                    @if (officer.AssignedDropOffPoint != null)
                                    {
                                        <span class="badge bg-success">@officer.AssignedDropOffPoint.Name</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Not Assigned</span>
                                    }
                                </td>
                                <td>
                                    <!-- ✅ CORRECT URL: /Admin/AssignOfficer/{id} -->
                                    <a href="@Url.Action("AssignOfficer", "Admin", new { id = officer.OfficerId })" class="btn btn-sm btn-primary">
                                        <i class="fas fa-map-pin"></i> Assign Region
                                    </a>
                                    <a href="@Url.Action("EditOfficer", "Admin", new { id = officer.OfficerId })" class="btn btn-sm btn-warning">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">No officers found.</p>
            }
        </div>
    </div>

    <div class="mt-3">
        @Html.ActionLink("← Back to Dashboard", "Dashboard", "Admin", null, new { @class = "btn btn-outline-secondary" })
    </div>
</div>