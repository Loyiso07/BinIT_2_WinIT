@model IEnumerable<BinIT2WinIT.Models.DropOffPoint>

@{
    ViewBag.Title = "Manage Drop-Off Points";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center">
        <h2><i class="fas fa-map-pin text-success"></i> Drop-Off Points</h2>
        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createModal">
            <i class="fas fa-plus"></i> Add New Location
        </button>
    </div>
    <hr />

    <div class="card shadow">
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th>Name</th>
                                <th>Address</th>
                                <th>City</th>
                                <th>Contact</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var point in Model.OrderBy(p => p.Name))
                            {
                                <tr>
                                    <td><strong>@point.Name</strong></td>
                                    <td>@point.Address</td>
                                    <td>@point.City</td>
                                    <td>
                                        @point.ContactPerson<br />
                                        <small>@point.PhoneNumber</small>
                                    </td>
                                    <td>
                                        @if (point.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        @if (point.IsActive)
                                        {
                                            using (Html.BeginForm("DeleteDropOffPoint", "Admin", FormMethod.Post, new { style = "display:inline;" }))
                                            {
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@point.DropOffPointId" />
                                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Deactivate this location?')">
                                                    <i class="fas fa-times"></i> Deactivate
                                                </button>
                                            }
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-secondary" disabled>Deactivated</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="fas fa-map-pin fa-3x text-muted"></i>
                    <p class="text-muted mt-2">No drop-off points found. Create one now!</p>
                </div>
            }
        </div>
    </div>

    <div class="mt-3">
        @Html.ActionLink("← Back to Dashboard", "Dashboard", "Admin", null, new { @class = "btn btn-outline-secondary" })
    </div>
</div>

<!-- Create Drop-Off Point Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            @using (Html.BeginForm("CreateDropOffPoint", "Admin", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="fas fa-plus"></i> Add Drop-Off Point</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="form-group mb-3">
                        <label for="Name" class="form-label fw-semibold">Location Name</label>
                        <input type="text" name="Name" class="form-control" placeholder="e.g. Durban City Centre" required />
                    </div>
                    <div class="form-group mb-3">
                        <label for="Address" class="form-label fw-semibold">Address</label>
                        <input type="text" name="Address" class="form-control" placeholder="Street address" required />
                    </div>
                    <div class="form-group mb-3">
                        <label for="City" class="form-label fw-semibold">City</label>
                        <input type="text" name="City" class="form-control" placeholder="e.g. Durban" required />
                    </div>
                    <div class="form-group mb-3">
                        <label for="Suburb" class="form-label fw-semibold">Suburb</label>
                        <input type="text" name="Suburb" class="form-control" placeholder="e.g. CBD" />
                    </div>
                    <div class="form-group mb-3">
                        <label for="ContactPerson" class="form-label fw-semibold">Contact Person</label>
                        <input type="text" name="ContactPerson" class="form-control" placeholder="Full name" />
                    </div>
                    <div class="form-group mb-3">
                        <label for="PhoneNumber" class="form-label fw-semibold">Phone Number</label>
                        <input type="text" name="PhoneNumber" class="form-control" placeholder="e.g. 031-555-0101" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Create Location
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}