@model BinIT2WinIT.Models.PointsRate

@{
    ViewBag.Title = "Create Points Rate";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h4><i class="fas fa-plus"></i> Add New Points Rate</h4>
                </div>
                <div class="card-body">
                    @using (Html.BeginForm("CreatePointsRate", "Admin", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <div class="form-group mb-3">
                            @Html.LabelFor(m => m.MaterialTypeId, new { @class = "form-label fw-semibold" })
                            @Html.DropDownListFor(
                                m => m.MaterialTypeId,
                                (SelectList)ViewBag.MaterialTypes,
                                "-- Select Material --",
                                new { @class = "form-control" }
                            )
                            @Html.ValidationMessageFor(m => m.MaterialTypeId, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group mb-3">
                            @Html.LabelFor(m => m.PointsPerKg, new { @class = "form-label fw-semibold" })
                            @Html.TextBoxFor(m => m.PointsPerKg, new { @class = "form-control", placeholder = "e.g. 5" })
                            @Html.ValidationMessageFor(m => m.PointsPerKg, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group mb-3">
                            @Html.LabelFor(m => m.EffectiveDate, new { @class = "form-label fw-semibold" })
                            @Html.TextBoxFor(m => m.EffectiveDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                            @Html.ValidationMessageFor(m => m.EffectiveDate, "", new { @class = "text-danger" })
                        </div>

                        <div class="mt-3">
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-save"></i> Create Rate
                            </button>
                            @Html.ActionLink("Cancel", "PointsRates", "Admin", null, new { @class = "btn btn-secondary ms-2" })
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}