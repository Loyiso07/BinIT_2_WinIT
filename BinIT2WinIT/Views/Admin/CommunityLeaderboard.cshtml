@model IEnumerable<BinIT2WinIT.Models.DropOffPoint>

@{
    ViewBag.Title = "Community Leaderboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2><i class="fas fa-trophy text-warning"></i> Community Recycling Leaderboard</h2>
    <p class="text-muted">See which communities are recycling the most!</p>
    <hr />

    <div class="card shadow">
        <div class="card-header bg-dark text-white">
            <i class="fas fa-crown"></i> Top Recycling Communities
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Rank</th>
                                <th>Community</th>
                                <th>City</th>
                                <th>Total Weight</th>
                                <th>CO2 Saved</th>
                                <th>Residents</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int rank = 1;
                            }
                            @foreach (var community in Model.OrderByDescending(c => ViewBag.TotalWeight[c.DropOffPointId]))
                            {
                                <tr>
                                    <td>
                                        @if (rank == 1)
                                        {
                                            <span class="badge bg-warning">🥇 1</span>
                                        }
                                        else if (rank == 2)
                                        {
                                            <span class="badge bg-secondary">🥈 2</span>
                                        }
                                        else if (rank == 3)
                                        {
                                            <span class="badge bg-danger">🥉 3</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-dark">@rank</span>
                                        }
                                    </td>
                                    <td><strong>@community.Name</strong></td>
                                    <td>@community.City</td>
                                    <td>@ViewBag.TotalWeight[community.DropOffPointId].ToString("0.0") kg</td>
                                    <td>@ViewBag.TotalCO2[community.DropOffPointId].ToString("0.0") kg</td>
                                    <td>@ViewBag.ResidentCounts[community.DropOffPointId]</td>
                                    <td>
                                        @if (community.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactive</span>
                                        }
                                    </td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="fas fa-trophy fa-3x text-muted"></i>
                    <p class="text-muted mt-2">No communities found.</p>
                </div>
            }
        </div>
    </div>

    <div class="mt-3">
        @Html.ActionLink("← Back to Dashboard", "Dashboard", "Admin", null, new { @class = "btn btn-outline-secondary" })
    </div>
</div>

