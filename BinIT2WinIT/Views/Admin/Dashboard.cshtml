@{
    ViewBag.Title = "Admin Dashboard";
}

<div class="container mt-4">
    <h2><i class="fas fa-cog text-success"></i> Administrator Dashboard</h2>

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white">
                <div class="card-body text-center">
                    <h3>@ViewBag.TotalResidents</h3>
                    <p>Total Residents</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <h3>@ViewBag.TotalSubmissions</h3>
                    <p>Total Submissions</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-warning text-dark">
                <div class="card-body text-center">
                    <h3>@ViewBag.TotalPoints</h3>
                    <p>Total Points Awarded</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <i class="fas fa-coins"></i> Points Rates
                </div>
                <div class="card-body">
                    @Html.ActionLink("Manage Points Rates", "PointsRates", "Admin", null, new { @class = "btn btn-outline-success" })
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <i class="fas fa-users"></i> Users
                </div>
                <div class="card-body">
                    @Html.ActionLink("Manage Users", "Users", "Admin", null, new { @class = "btn btn-outline-primary" })
                </div>
            </div>
        </div>
    </div>
</div>