@model BinIT2WinIT.Models.AssignOfficerViewModel

@{
    ViewBag.Title = "Assign Region";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4><i class="fas fa-map-pin"></i> Assign Region to Officer</h4>
                </div>
                <div class="card-body">
                    @using (Html.BeginForm("AssignOfficer", "Admin", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(m => m.OfficerId)

                        <div class="form-group mb-3">
                            <label class="form-label fw-semibold">Officer</label>
                            <p class="form-control-static"><strong>@Model.OfficerName</strong></p>
                        </div>

                        <div class="form-group mb-3">
                            @Html.LabelFor(m => m.DropOffPointId, new { @class = "form-label fw-semibold" })
                            @Html.DropDownListFor(
                                m => m.DropOffPointId,
                                Model.DropOffPoints,
                                "-- Select Region --",
                                new { @class = "form-control form-control-lg" }
                            )
                            @Html.ValidationMessageFor(m => m.DropOffPointId, "", new { @class = "text-danger" })
                        </div>

                        <!-- Available Regions Info -->
                        if (Model.DropOffPoints != null && Model.DropOffPoints.Any())
                        {
                            <div class="alert alert-info">
                                <strong>Available Regions:</strong>
                                <ul>
                                    @foreach (var item in Model.DropOffPoints)
                                    {
                                        <li>@item.Text (ID: @item.Value)</li>
                                    }
                                </ul>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning">
                                <i class="fas fa-exclamation-triangle"></i>
                                No drop-off points found. Please create one first.
                                @Html.ActionLink("Create Drop-Off Point", "DropOffPoints", "Admin", null, new { @class = "btn btn-sm btn-success ms-2" })
                            </div>
                        }

                        <div class="mt-3">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Assign Region
                            </button>
                            @Html.ActionLink("Cancel", "Officers", "Admin", null, new { @class = "btn btn-secondary ms-2" })
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}