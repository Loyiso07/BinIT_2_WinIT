@model IEnumerable<BinIT2WinIT.Models.PointsRate>

@{
    ViewBag.Title = "Points Rates";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <!-- Success/Error Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center">
        <h2><i class="fas fa-coins text-warning"></i> Points Rates</h2>
        @Html.ActionLink("+ Add New Rate", "CreatePointsRate", "Admin", null, new { @class = "btn btn-success" })
    </div>
    <hr />

    <div class="card shadow">
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th>Material Type</th>
                                <th>Points Per Kg</th>
                                <th>Effective Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rate in Model.OrderByDescending(r => r.IsActive))
                            {
                                <tr>
                                    <td>@(rate.MaterialType?.Name ?? "Unknown")</td>
                                    <td><strong>@rate.PointsPerKg</strong></td>
                                    <td>@rate.EffectiveDate.ToShortDateString()</td>
                                    <td>
                                        @if (rate.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        @if (rate.IsActive)
                                        {
                                            @Html.ActionLink("Deactivate", "DeactivateRate", "Admin", new { id = rate.PointsRateId }, new { @class = "btn btn-danger btn-sm" })
                                        }
                                        else
                                        {
                                            <span class="text-muted">Deactivated</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="fas fa-coins fa-3x text-muted"></i>
                    <p class="text-muted mt-2">No points rates found. Click "Add New Rate" to create one.</p>
                </div>
            }
        </div>
    </div>

    <div class="mt-3">
        @Html.ActionLink("← Back to Dashboard", "Dashboard", "Admin", null, new { @class = "btn btn-outline-secondary" })
    </div>
</div>