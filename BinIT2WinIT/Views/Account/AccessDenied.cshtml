@{
    ViewBag.Title = "Access Denied";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-lg mt-5">
            <div class="card-header bg-danger text-white text-center">
                <h4><i class="fas fa-exclamation-triangle"></i> Access Denied</h4>
            </div>
            <div class="card-body text-center">
                <i class="fas fa-lock fa-5x text-danger mb-3"></i>
                <h5>You do not have permission to access this page.</h5>
                <p class="text-muted">Please contact your administrator if you believe this is an error.</p>
                @Html.ActionLink("← Return to Home", "Index", "Home", null, new { @class = "btn btn-primary" })
            </div>
        </div>
    </div>
</div>